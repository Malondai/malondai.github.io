---
interface Props {
	projects: Array<{
		title: string;
		desc: string;
		url?: string;
		image?: string;
		tags?: string[];
	}>;
}

const { projects } = Astro.props;
---

<section id="projects" class="scroll-mt-16 lg:scroll-mt-24">
	<div class="sticky top-0 z-20 -mx-6 mb-4 w-screen bg-slate-900/75 px-6 py-5 backdrop-blur md:-mx-12 md:px-12 lg:hidden">
		<h2 class="text-sm font-bold uppercase tracking-widest text-slate-200">Projects</h2>
	</div>
	<ul class="group/list">
		{
			projects.map((p) => (
				<li class="mb-12">
					<div class="group relative grid gap-4 pb-1 transition-all sm:grid-cols-8 sm:gap-8 md:gap-4 lg:hover:!opacity-100 lg:group-hover/list:opacity-50">
						<div class="absolute -inset-x-4 -inset-y-4 z-0 hidden rounded-md transition motion-reduce:transition-none lg:-inset-x-6 lg:block lg:group-hover:bg-slate-800/50 lg:group-hover:shadow-[inset_0_1px_0_0_rgba(148,163,184,0.1)] lg:group-hover:drop-shadow-lg" />
						<div class="z-10 sm:col-span-2">
							<div class="rounded border-2 border-slate-200/10 transition group-hover:border-slate-200/30 sm:order-1 sm:col-span-2 sm:translate-y-1 overflow-hidden relative z-20">
								<div class="w-full aspect-video bg-slate-800/50 flex items-center justify-center opacity-50 group-hover:opacity-100 transition-opacity">
									{p.image ? (
										<img 
											src={p.image} 
											alt={`${p.title} thumbnail`} 
											class="w-full h-full object-cover cursor-pointer project-image-trigger" 
											data-project-title={p.title}
											title="Click to enlarge"
										/>
									) : (
										<span class="text-[10px] font-mono font-bold uppercase tracking-widest opacity-30 text-slate-200">Project</span>
									)}
								</div>
							</div>
						</div>
						<div class="z-10 sm:col-span-6">
							<h3 class="font-medium leading-snug text-slate-200">
								<div>
									{p.url && p.url !== "#" ? (
										<a class="inline-flex items-baseline font-medium leading-tight text-slate-200 hover:text-teal-300 focus-visible:text-teal-300  group/link text-base" href={p.url} target="_blank" rel="noreferrer noopener" aria-label={p.title}>
											<span class="absolute -inset-x-4 -inset-y-4 hidden rounded md:-inset-x-6 md:-inset-y-6 lg:block"></span>
											<span>
												{p.title}
												<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="inline-block h-4 w-4 shrink-0 transition-transform group-hover/link:-translate-y-1 group-hover/link:translate-x-1 focus-visible:translate-y-1 focus-visible:translate-x-1 motion-reduce:transition-none ml-1 translate-y-px" aria-hidden="true"><path fill-rule="evenodd" d="M5.22 14.78a.75.75 0 001.06 0l7.22-7.22v5.69a.75.75 0 001.5 0v-7.5a.75.75 0 00-.75-.75h-7.5a.75.75 0 000 1.5h5.69l-7.22 7.22a.75.75 0 000 1.06z" clip-rule="evenodd"></path></svg>
											</span>
										</a>
									) : (
										<div class="text-base font-medium leading-tight text-slate-200">
											{p.title}
										</div>
									)}
								</div>
							</h3>
							<p class="mt-2 text-sm leading-normal text-slate-400">
								{p.desc}
							</p>
							
							{p.url && p.url !== "#" && (
								<div class="mt-4 flex items-center">
									<a href={p.url} target="_blank" rel="noreferrer noopener" class="inline-flex items-center gap-1 text-xs font-medium text-slate-300 hover:text-teal-300 transition-colors z-20">
										<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-3 w-3">
											<path d="M12.232 4.232a2.5 2.5 0 0 1 3.536 3.536l-1.225 1.224a.75.75 0 0 0 1.061 1.06l1.224-1.224a4 4 0 0 0-5.656-5.656l-3 3a4 4 0 0 0 .225 5.865.75.75 0 0 0 .977-1.138 2.5 2.5 0 0 1-.142-3.667l3-3Z" />
											<path d="M11.603 7.963a.75.75 0 0 0-.977 1.138 2.5 2.5 0 0 1 .142 3.667l-3 3a2.5 2.5 0 0 1-3.536-3.536l1.225-1.224a.75.75 0 0 0-1.061-1.06l-1.224 1.224a4 4 0 1 0 5.656 5.656l3-3a4 4 0 0 0-.225-5.865Z" />
										</svg>
										{p.url.replace(/^https?:\/\/(www\.)?/, '').replace(/\/$/, '')}
									</a>
								</div>
							)}

							{p.tags && (
								<ul class="mt-4 flex flex-wrap gap-2" aria-label="Technologies used">
									{p.tags.map((t) => (
										<li class="mr-1.5 mt-2">
											<div class="flex items-center rounded-full bg-teal-400/10 px-3 py-1 text-xs font-medium leading-5 text-teal-300">
												{t}
											</div>
										</li>
									))}
								</ul>
							)}
						</div>
					</div>
				</li>
			))
		}
	</ul>
</section>
