---
interface Props {
    profile: {
        name: string;
        role: string;
        bio: string;
        socials: {
            github: string;
            linkedin: string;
            instagram: string;
        };
    };
}

const { profile } = Astro.props;
---

<header
    class="lg:sticky lg:top-0 lg:flex lg:h-screen lg:w-1/2 lg:flex-col lg:justify-between lg:py-24 animate-reveal z-50 lg:overflow-y-hidden"
>
    <div>
        <div class="flex items-center gap-4 md:gap-8 mb-12">
            <div class="animate-reveal shrink-0">
                <img 
                    src={profile.avatar} 
                    alt={profile.name} 
                    class="w-20 h-20 md:w-32 md:h-32 rounded-[1.5rem] md:rounded-[2rem] object-cover shadow-2xl border-2 border-primary/20 grayscale-0 md:grayscale md:hover:grayscale-0 transition-all duration-700 ease-in-out"
                />
            </div>
            <div>
                <h1 class="text-3xl md:text-5xl lg:text-6xl font-black tracking-tighter italic font-mono leading-tight">
                    {profile.name.toUpperCase()}<span class="text-primary">.</span>
                </h1>
                <h2 class="mt-1 md:mt-2 text-lg md:text-2xl font-bold tracking-tight opacity-90">
                    {profile.role}
                </h2>
            </div>
        </div>

        <nav class="mt-16 hidden lg:block">
            <ul
                class="flex flex-col gap-6 uppercase tracking-[0.3em] text-[10px] font-black font-mono"
            >
                <li>
                    <a
                        href="#about"
                        id="nav-about"
                        class="nav-link group flex items-center py-3"
                        ><span
                            class="nav-indicator mr-4 h-px w-8 bg-slate-600 transition-all group-hover:w-16 group-hover:bg-primary"
                        ></span> ABOUT</a
                    >
                </li>
                <li>
                    <a
                        href="#exp"
                        id="nav-exp"
                        class="nav-link group flex items-center py-3"
                        ><span
                            class="nav-indicator mr-4 h-px w-8 bg-slate-600 transition-all group-hover:w-16 group-hover:bg-primary"
                        ></span> EXPERIENCE</a
                    >
                </li>
                <li>
                    <a
                        href="#projects"
                        id="nav-projects"
                        class="nav-link group flex items-center py-3"
                        ><span
                            class="nav-indicator mr-4 h-px w-8 bg-slate-600 transition-all group-hover:w-16 group-hover:bg-primary"
                        ></span> PROJECTS</a
                    >
                </li>
            </ul>
        </nav>
    </div>

    <div
        class="mt-12 flex gap-5 items-center"
    >
        <a
            class="block hover:text-slate-200 text-slate-400 transition-colors"
            href={profile.socials.github}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
        >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-6 w-6" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
        </a>
        <a
            class="block hover:text-slate-200 text-slate-400 transition-colors"
            href={profile.socials.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
        >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-6 w-6" aria-hidden="true"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.238 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
        </a>
        <a
            class="block hover:text-slate-200 text-slate-400 transition-colors"
            href={profile.socials.instagram}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
        >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
        </a>
    </div>
</header>
