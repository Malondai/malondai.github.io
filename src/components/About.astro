---
interface Props {
	bio: string;
}

const { bio } = Astro.props;
---

<section id="about" class="scroll-mt-16 lg:scroll-mt-24">
	<div class="sticky top-0 z-20 -mx-6 mb-4 w-screen bg-slate-900/75 px-6 py-5 backdrop-blur md:-mx-12 md:px-12 lg:hidden">
		<h2 class="text-sm font-bold uppercase tracking-widest text-slate-200">About</h2>
	</div>
	<div>
		<p class="leading-relaxed opacity-70 font-medium">
			{bio}
		</p>
	</div>
</section>
