---
interface Props {
    title?: string;
}

const { title = "Muhammad Mahatir | Fullstack Developer" } = Astro.props;
---

<!doctype html>
<html lang="id" class="scroll-smooth" data-theme="night">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/portofolio/favicon.svg" />
        <link rel="icon" href="/portofolio/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <slot name="head" />
        <script is:inline>
            // Force night theme and clear old preferences
            document.documentElement.setAttribute("data-theme", "night");
            localStorage.removeItem("theme");
        </script>
    </head>
    <body class="bg-base-100 text-base-content min-h-screen">
        <slot />
    </body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
	}
</style>
